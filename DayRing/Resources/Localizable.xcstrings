      "localizations" : {
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "补班日响铃" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "補班日響鈴" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Ring on Makeup Days" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "振替出勤日に鳴らす" } }
      }
    },
    "查看日历覆盖" : {
      "localizations" : {
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "查看日历覆盖" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "查看日曆覆蓋" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "View Calendar Overrides" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "カレンダーのオーバーライドを見る" } }
      }
    },
    "开启后，节假日自动跳过闹钟，补班日自动恢复响铃。也可以在日历中手动覆盖某天的响铃状态。" : {
      "localizations" : {
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "开启后，节假日自动跳过闹钟，补班日自动恢复响铃。也可以在日历中手动覆盖某天的响铃状态。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "開啟後，節假日自動跳過鬧鐘，補班日自動恢復響鈴。也可以在日曆中手動覆蓋某天的響鈴狀態。" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "When enabled, alarms are automatically skipped on holidays and restored on makeup workdays. You can also manually override the ring status for any day in the calendar." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "有効にすると、祝日にはアラームが自動でスキップされ、振替出勤日には自動で復元されます。カレンダーで手動で各日の鳴動状態を変更することもできます。" } }
      }
    },
    "当天闹钟响铃状态" : {
      "localizations" : {
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "当天闹钟响铃状态" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "當天鬧鐘響鈴狀態" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Alarm Status for This Day" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "この日のアラーム状態" } }
      }
    },
    "暂无闹钟" : {
      "localizations" : {
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "暂无闹钟" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "暫無鬧鐘" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "No Alarms" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "アラームなし" } }
      }
    },
    "开启开关可手动覆盖该天的闹钟响铃状态，优先级高于自动规则。" : {
      "localizations" : {
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "开启开关可手动覆盖该天的闹钟响铃状态，优先级高于自动规则。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "開啟開關可手動覆蓋該天的鬧鐘響鈴狀態，優先級高於自動規則。" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Toggle to manually override the alarm status for this day. Manual overrides take priority over automatic rules." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "スイッチをオンにすると、この日のアラーム状態を手動で変更できます。手動設定は自動ルールより優先されます。" } }
      }
    },
